{
  "name": "myintern",
  "version": "1.3.2",
  "description": "Compliance-first AI coding agent that fixes production errors while you sleep — self-hosted, BYOK, with audit trails",
  "main": "dist/index.js",
  "bin": {
    "myintern": "dist/cli/index.js"
  },
  "files": [
    "dist/**/*",
    "templates/**/*",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "build:production": "npm run clean && npm run build && npm run add-license-headers && npm run verify-build",
    "clean": "rm -rf dist/",
    "add-license-headers": "node scripts/add-license-headers.js",
    "verify-build": "node scripts/verify-build.js",
    "prepublishOnly": "npm run build:production",
    "dev": "ts-node src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "jest",
    "test:e2e": "npm run build && tests/e2e/test-runner.sh",
    "test:generate": "ts-node scripts/generate-tests.ts",
    "test:all": "npm test && npm run test:e2e",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "pack:test": "npm run build:production && npm pack --dry-run"
  },
  "keywords": [
    "ai",
    "agent",
    "java",
    "spring-boot",
    "developer",
    "automation",
    "code-generation",
    "compliance-first",
    "production-monitoring",
    "self-hosted",
    "hipaa"
  ],
  "author": "Prasols",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/myinterndev/myintern"
  },
  "bugs": {
    "url": "https://myintern.dev/support"
  },
  "homepage": "https://myintern.dev",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-bedrock-runtime": "^3.995.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1003.0",
    "@aws-sdk/credential-providers": "^3.995.0",
    "@octokit/rest": "^20.0.2",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "inquirer": "^9.2.15",
    "js-yaml": "^4.1.0",
    "openai": "^4.28.0",
    "prompts": "^2.4.2",
    "simple-git": "^3.22.0",
    "winston": "^3.11.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.5",
    "@types/prompts": "^2.4.9",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "minimatch": "^10.0.1",
    "glob": "^11.0.0"
  }
}
