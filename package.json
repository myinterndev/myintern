{
  "name": "myintern",
  "version": "1.2.0",
  "description": "Your AI Junior Developer for Java/Spring Boot Projects - Production-ready with Guardrails, Multi-Repo Support, and Enterprise Security",
  "main": "dist/index.js",
  "bin": {
    "myintern": "dist/cli/index.js"
  },
  "files": [
    "dist/**/*",
    "templates/**/*",
    "docs/**/*",
    "examples/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "jest",
    "test:e2e": "npm run build && tests/e2e/test-runner.sh",
    "test:generate": "ts-node scripts/generate-tests.ts",
    "test:all": "npm test && npm run test:e2e",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "ai",
    "agent",
    "java",
    "spring-boot",
    "developer",
    "automation",
    "code-generation",
    "junior-developer",
    "autonomous-agent"
  ],
  "author": "Prasols",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/myinterndev/myintern.git"
  },
  "bugs": {
    "url": "https://github.com/myinterndev/myintern/issues"
  },
  "homepage": "https://github.com/myinterndev/myintern#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-bedrock-runtime": "^3.995.0",
    "@aws-sdk/credential-providers": "^3.995.0",
    "@octokit/rest": "^20.0.2",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "inquirer": "^9.2.15",
    "js-yaml": "^4.1.0",
    "openai": "^4.28.0",
    "prompts": "^2.4.2",
    "simple-git": "^3.22.0",
    "winston": "^3.11.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.5",
    "@types/prompts": "^2.4.9",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "minimatch": "^10.0.1",
    "glob": "^11.0.0"
  }
}
